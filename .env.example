# ─── Secret Keys (Flask) ───────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY_LANDING=GENERATE_A_RANDOM_64_CHAR_KEY_HERE
SECRET_KEY_CGRF=GENERATE_A_RANDOM_64_CHAR_KEY_HERE
SECRET_KEY_PAWSTEPS=GENERATE_A_RANDOM_64_CHAR_KEY_HERE
SECRET_KEY_SHOP=GENERATE_A_RANDOM_64_CHAR_KEY_HERE
SECRET_KEY_ADMIN=GENERATE_A_RANDOM_64_CHAR_KEY_HERE

# ─── Admin Bootstrap ──────────────────────
ADMIN_INITIAL_PASSWORD=CHANGE_THIS_ON_FIRST_LOGIN

# ─── Database Paths (Docker internal) ─────
CGRF_DB_PATH=/app/shared_data/cgrf/base_cgrf.db
PAWSTEPS_DB_PATH=/app/shared_data/pawsteps/pawsteps.db
SHOP_DB_PATH=/app/shared_data/shop/shop.db

# ─── Domains ──────────────────────────────
CGRF_DOMAIN=cgrf.com.br
PAWSTEPS_DOMAIN=pawsteps.social
SHOP_DOMAIN=furrycore.com.br
LANDING_DOMAIN=furrycore.com.br
ADMIN_DOMAIN=arwolf.com.br

# ─── E-mail (SMTP) ───────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ─── Monitoramento (Zabbix) ──────────────
ZBX_SERVER_HOST=187.77.233.230
ZBX_HOSTNAME=SRV-AUTOMACAO

# ─── Runtime ─────────────────────────────
FLASK_ENV=production
DEBUG=False
MAX_UPLOAD_SIZE=10485760
