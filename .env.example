# ─── Secret Keys (Flask) ───────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY_LANDING=GENERATE_A_RANDOM_64_CHAR_KEY_HERE_LANDING
SECRET_KEY_CGRF=GENERATE_A_RANDOM_64_CHAR_KEY_HERE_CGRF
SECRET_KEY_PAWSTEPS=GENERATE_A_RANDOM_64_CHAR_KEY_HERE_PAWSTEPS
SECRET_KEY_SHOP=GENERATE_A_RANDOM_64_CHAR_KEY_HERE_SHOP
SECRET_KEY_ADMIN=GENERATE_A_RANDOM_64_CHAR_KEY_HERE_ADMIN

# ─── Admin Bootstrap ──────────────────────
ADMIN_INITIAL_PASSWORD=CHANGE_THIS_ON_FIRST_LOGIN

# ─── Database Paths (Docker) ──────────────
